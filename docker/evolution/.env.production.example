# Copie para .env.production na VPS e troque TODOS os valores.
# Nunca commite .env.production no Git.

# --- Auth (mesma chave no Vercel: EVOLUTION_API_KEY) ---
AUTHENTICATION_API_KEY=troque-por-chave-longa-e-aleatoria

# URL pública HTTPS da Evolution (após Caddy + DNS)
# Ex.: https://evolution.seudominio.com
SERVER_URL=https://evolution.seudominio.com

# --- Postgres (interno ao Docker) ---
POSTGRES_USER=evolution
POSTGRES_PASSWORD=troque-por-senha-forte-postgres
POSTGRES_DB=evolution
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:troque-por-senha-forte-postgres@evolution-postgres:5432/evolution?schema=public
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true

# --- Redis ---
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://evolution-redis:6379/1

# --- Webhook → PoliticRank na Vercel ---
# Ex.: https://seu-app.vercel.app/api/webhooks/whatsapp/evolution
WEBHOOK_GLOBAL_URL=https://seu-app.vercel.app/api/webhooks/whatsapp/evolution
WEBHOOK_GLOBAL_ENABLED=true
WEBHOOK_EVENTS_MESSAGES_UPSERT=true
WEBHOOK_EVENTS_CONNECTION_UPDATE=true
WEBHOOK_EVENTS_GROUPS_UPSERT=true
WEBHOOK_EVENTS_GROUP_PARTICIPANTS_UPDATE=true
